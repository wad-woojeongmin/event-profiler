# 로컬 개발용 환경변수 템플릿.
# 이 파일을 복사해 .env로 만들고 실제 값을 채운다. 실제 .env는 커밋하지 않는다.
#
#   cp .env.example .env
#
# 실제 값은 리포 외부 안전한 위치에 보관된 자격증명 기록에서 확인한다.

# Google OAuth 2.0 Client ID (Chrome Extension type).
# Sheets API 읽기 전용 스코프 — spreadsheets.readonly.
WXT_OAUTH_CLIENT_ID=

# MV3 manifest 공개 키 (base64, RSA 2048).
# Extension ID를 고정해 Google Cloud OAuth client에 등록한 ID와 일치시키는 용도.
# 대응되는 .pem 개인 키는 팀 비밀번호 매니저에만 보관(리포 커밋 금지).
WXT_EXTENSION_PUBLIC_KEY=
